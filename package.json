{
  "name": "kilne-git",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "expo": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-file-system": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "kilne-git-native": "link:./modules/kilne-git-native",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "nitrogen": "*",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:release": "cd android && ./gradlew app:assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "nitrogen": "cd modules/kilne-git-native && npx nitrogen",
    "prebuild:clean": "rm -rf modules/kilne-git-native/android/.cxx modules/kilne-git-native/android/build && pnpm nitrogen && expo prebuild --clean --platform android",
    "prebuild:clean:win": "cmd /c \"if exist modules\\kilne-git-native\\android\\.cxx rmdir /s /q modules\\kilne-git-native\\android\\.cxx & if exist modules\\kilne-git-native\\android\\build rmdir /s /q modules\\kilne-git-native\\android\\build\" && pnpm nitrogen && expo prebuild --clean --platform android"
  },
  "private": true
}
